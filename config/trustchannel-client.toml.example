# Private TrustChannel client config.
# Copy this file to config/trustchannel-client.toml and fill your real credentials.

hostname = "example.trustchannel.host"
addresses = ["203.0.113.10:443"]
custom_sni = ""
has_ipv6 = true
username = "replace-me"
password = "replace-me"
client_random_prefix = ""
skip_verification = false
certificate = """
-----BEGIN CERTIFICATE-----
REPLACE_WITH_REAL_CERTIFICATE
-----END CERTIFICATE-----
"""
upstream_protocol = "http2"
anti_dpi = false
